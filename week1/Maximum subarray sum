#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    long long ans = LLONG_MIN, curr = 0;

    for (int i = 0; i < n; i++) {
        long long x;
        cin >> x;

        curr = max(x, curr + x);
        ans = max(ans, curr);
    }

    cout << ans << "\n";

    return 0;
}
