#include <bits/stdc++.h>
using namespace std;

using int64 = long long;
const int64 INF = (1LL << 60);

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;
        string s;
        cin >> s;

        if (n == 2) {
            cout << stoi(s) << "\n";
            continue;
        }

        int64 ans = INF;

        for (int k = 0; k < n - 1; k++) {
            vector<int64> a;

            for (int i = 0; i < n; ) {
                if (i == k) {
                    a.push_back((s[i] - '0') * 10 + (s[i + 1] - '0'));
                    i += 2;
                } else {
                    a.push_back(s[i] - '0');
                    i++;
                }
            }

            int m = a.size();

            vector<vector<int64>> prod(m, vector<int64>(m));

            for (int i = 0; i < m; i++) {
                __int128 cur = 1;
                for (int j = i; j < m; j++) {
                    cur *= a[j];
                    if (cur > INF) cur = INF;
                    prod[i][j] = (int64)cur;
                }
            }

            vector<int64> dp(m + 1, INF);
            dp[0] = 0;

            for (int i = 1; i <= m; i++) {
                for (int j = 1; j <= i; j++) {
                    dp[i] = min(dp[i], dp[j - 1] + prod[j - 1][i - 1]);
                }
            }

            ans = min(ans, dp[m]);
        }

        cout << ans << "\n";
    }

    return 0;
}
