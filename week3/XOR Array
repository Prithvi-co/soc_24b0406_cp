#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n, l, r;
        cin >> n >> l >> r;

        for (int i = 1; i <= n; i++) {
            int x = (i - 1) ^ i;

            if (i == r)
                x = (l - 1) ^ (r - 1);
            else if (i == r + 1)
                x = (l - 1) ^ i;

            cout << x << " ";
        }
        cout << "\n";
    }

    return 0;
}
