#include <bits/stdc++.h>
using namespace std;

using int64 = long long;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<int64> p(n), s(n), a(n);

        for (int i = 0; i < n; i++) cin >> p[i];
        for (int i = 0; i < n; i++) cin >> s[i];

        for (int i = 0; i < n; i++) {
            int64 g = gcd(p[i], s[i]);
            a[i] = (p[i] / g) * s[i];
        }

        bool ok = true;

        int64 g = 0;
        for (int i = 0; i < n; i++) {
            g = gcd(g, a[i]);
            if (g != p[i]) {
                ok = false;
                break;
            }
        }

        if (ok) {
            g = 0;
            for (int i = n - 1; i >= 0; i--) {
                g = gcd(g, a[i]);
                if (g != s[i]) {
                    ok = false;
                    break;
                }
            }
        }

        cout << (ok ? "Yes" : "No") << '\n';
    }

    return 0;
}
