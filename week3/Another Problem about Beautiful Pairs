#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;

        vector<int> pos(n + 1, -1);

        for (int i = 1; i <= n; i++) {
            int x;
            cin >> x;
            if (x <= n)
                pos[x] = i;
        }

        long long ans = 0;

        for (int x = 1; x <= n; x++) {
            if (pos[x] == -1)
                continue;

            for (int y = x + 1; x * y < 2 * n; y++) {
                if (y > n)
                    break;
                if (pos[y] == -1)
                    continue;

                if (abs(pos[x] - pos[y]) == x * y)
                    ans++;
            }
        }

        cout << ans << "\n";
    }

    return 0;
}
